{
    "name": "test-project/php-blog",
    "description": "Simple blog on pure PHP 8 with Smarty templating and MySQL",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "smarty/smarty": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "seed": "php database/seed.php"
    }
}
